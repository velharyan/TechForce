@model TechForce.Web.Controllers.ContactForm
@inject Microsoft.Extensions.Options.IOptions<AppOptions> App
@{
    var normalizedWhatsApp = System.Text.RegularExpressions.Regex.Replace(App.Value.WhatsAppNumber ?? string.Empty, "[^0-9]", string.Empty);
    var whatsappHref = string.IsNullOrWhiteSpace(normalizedWhatsApp) ? string.Empty : $"https://wa.me/{normalizedWhatsApp}";
}
<section class="page-shell module-page theme-web">
    <div class="container">
        <header class="page-hero" data-reveal>
            <h1>Receba um plano tecnico completo para seu cenario</h1>
            <p>Compartilhe seu desafio e retornamos com proposta de arquitetura, etapas, prazo e recomendacao de rollout.</p>
        </header>

        <section class="info-strip" data-reveal>
            <article class="info-chip">
                <strong>Resposta consultiva</strong>
                <span>Diagnostico inicial com foco tecnico e comercial.</span>
            </article>
            <article class="info-chip">
                <strong>Plano claro de execucao</strong>
                <span>Prioridade por impacto, etapas e estimativa inicial.</span>
            </article>
            <article class="info-chip">
                <strong>Ponto focal dedicado</strong>
                <span>Comunicacao objetiva durante todo o ciclo do projeto.</span>
            </article>
        </section>

        <section class="contact-grid">
            <article class="card module-card" data-reveal data-hover-tilt>
                <h3>Canal direto com especialista</h3>
                <p>Atendimento consultivo para entender seu contexto e orientar a melhor estrategia de implantacao.</p>
                @if (!string.IsNullOrWhiteSpace(whatsappHref))
                {
                    <p><a class="btn btn-outline" href="@whatsappHref" target="_blank" rel="noopener noreferrer" data-evt="cta_whatsapp_contact">Falar no WhatsApp</a></p>
                }
                @if (!string.IsNullOrWhiteSpace(App.Value.ContactEmail))
                {
                    <p>E-mail: <a href="mailto:@App.Value.ContactEmail">@App.Value.ContactEmail</a></p>
                }
                <div class="contact-panel">
                    @if (!string.IsNullOrWhiteSpace(App.Value.ContactEmail))
                    {
                        <p class="contact-line"><span>E-mail principal</span><strong>@App.Value.ContactEmail</strong></p>
                    }
                    <p class="contact-line"><span>SLA medio de retorno</span><strong>Ate @App.Value.SlaHours horas uteis</strong></p>
                    <p class="contact-line"><span>Formato da primeira entrega</span><strong>Diagnostico + proposta inicial</strong></p>
                </div>
                <div class="module-kpis">
                    <article class="module-kpi">
                        <strong data-count-to="4">0</strong>
                        <span>etapas no kickoff</span>
                    </article>
                    <article class="module-kpi">
                        <strong data-count-to="2" data-count-suffix=" dias">0</strong>
                        <span>prazo para proposta inicial</span>
                    </article>
                    <article class="module-kpi">
                        <strong data-count-to="8" data-count-suffix="+">0</strong>
                        <span>areas de atuacao tecnica</span>
                    </article>
                    <article class="module-kpi">
                        <strong data-count-to="1">0</strong>
                        <span>ponto focal dedicado</span>
                    </article>
                </div>
            </article>

            <article class="card module-card contact-checklist" data-reveal data-delay="1">
                <h3>Informacoes que aceleram sua proposta</h3>
                <ul class="list-clean">
                    <li>Objetivo principal do projeto e meta de negocio</li>
                    <li>Processos que hoje geram gargalo operacional</li>
                    <li>Sistemas atuais e integracoes necessarias</li>
                    <li>Prazo esperado para primeira entrega em producao</li>
                    <li>Times envolvidos (comercial, operacao, financeiro, TI)</li>
                </ul>
                <div class="module-badges">
                    <span class="module-badge">Escopo</span>
                    <span class="module-badge">Prioridades</span>
                    <span class="module-badge">Riscos</span>
                    <span class="module-badge">Roadmap</span>
                </div>
                <ul class="timeline-list">
                    <li><strong>Dia 0:</strong> recebimento do briefing e triagem do contexto</li>
                    <li><strong>Dia 1:</strong> alinhamento tecnico-comercial e prioridades</li>
                    <li><strong>Dia 2:</strong> envio da proposta inicial com proximo passo</li>
                </ul>
            </article>
        </section>

        <section class="section-spaced card module-card" data-reveal>
            <h2>Formulario de proposta</h2>
            @if (TempData["Success"] != null)
            {
                <div class="alert success">@TempData["Success"]</div>
            }
            <form asp-action="Contact" method="post" class="form-grid">
                <div>
                    <label for="Name">Nome</label>
                    <input asp-for="Name" />
                    <span asp-validation-for="Name" class="validation"></span>
                </div>
                <div>
                    <label for="Company">Empresa</label>
                    <input asp-for="Company" />
                    <span asp-validation-for="Company" class="validation"></span>
                </div>
                <div>
                    <label for="Email">E-mail</label>
                    <input asp-for="Email" type="email" />
                    <span asp-validation-for="Email" class="validation"></span>
                </div>
                <div>
                    <label for="Phone">Telefone ou WhatsApp</label>
                    <input asp-for="Phone" />
                    <span asp-validation-for="Phone" class="validation"></span>
                </div>
                <div class="form-row-full">
                    <label for="Need">Necessidade</label>
                    <textarea asp-for="Need" placeholder="Descreva contexto, principal problema, objetivo e prazo desejado."></textarea>
                    <span asp-validation-for="Need" class="validation"></span>
                </div>
                <div class="form-row-full">
                    <button class="btn btn-primary" type="submit" data-evt="cta_contact_form">Enviar mensagem</button>
                </div>
            </form>
        </section>

        <section class="status-note section-spaced" data-reveal>
            Dica para acelerar: inclua no campo de necessidade o sistema atual, o maior gargalo e o prazo desejado para a primeira entrega.
        </section>
    </div>
</section>
