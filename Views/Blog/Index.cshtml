@model IEnumerable<TechForce.Web.Controllers.Post>
<section class="page-shell module-page theme-web">
    <div class="container">
        <header class="page-hero" data-reveal>
            <h1>Conteudo pratico para liderancas de negocio, operacao e tecnologia</h1>
            <p>Guias objetivos, checklists e experiencias de campo para apoiar decisoes de investimento digital com menos risco.</p>
        </header>

        <section class="info-strip" data-reveal>
            <article class="info-chip">
                <strong>Leitura objetiva</strong>
                <span>Artigos curtos com aplicacao imediata no negocio.</span>
            </article>
            <article class="info-chip">
                <strong>Baseado em cenario real</strong>
                <span>Conteudo com foco em operacao, vendas e governanca.</span>
            </article>
            <article class="info-chip">
                <strong>Proximo passo claro</strong>
                <span>Cada tema termina com acao pratica para executar.</span>
            </article>
        </section>

        <ul class="content-list">
            @foreach (var post in Model)
            {
                <li class="card" data-reveal data-hover-tilt>
                    <a href="/Blog/@post.Slug">
                        <h3>@post.Title</h3>
                        <p class="muted">@post.Excerpt</p>
                        <ul class="article-meta">
                            <li>Leitura de 4-6 min</li>
                            <li>Aplicacao pratica</li>
                            <li>Atualizado em 2026</li>
                        </ul>
                        <p class="small">Ler artigo completo</p>
                    </a>
                </li>
            }
        </ul>

        <section class="cta-panel section-spaced" data-reveal>
            <h2>Quer um conteudo aplicado ao seu cenario?</h2>
            <p>Podemos transformar esses aprendizados em um plano tecnico especifico para seu contexto de operacao e crescimento.</p>
            <div class="module-actions">
                <a class="btn btn-primary" href="/Company/Contact">Falar com especialista</a>
                <a class="btn btn-outline" href="/Services">Ver nossas solucoes</a>
            </div>
        </section>
    </div>
</section>
