@model NexCore.Web.Controllers.Post
<section class="container narrow">
  <nav class="breadcrumb"><a href="/">Início</a> / <a href="/Blog">Blog</a> / <span>@Model.Title</span></nav>
  <article>
    <h1>@Model.Title</h1>
    <p class="muted">@Model.Excerpt</p>
    <p>Conteúdo do post (placeholder). Substitua por texto real e otimize para SEO com headings, listas e links internos.</p>
  </article>
</section>