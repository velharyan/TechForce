                const sources = ["backlog", "doing", "done"];
                const sourceIndex = sources.findIndex((name) => state[name].some((task) => task.id === id));
                if (sourceIndex === -1) return;
                const targetIndex = direction === "next" ? sourceIndex + 1 : sourceIndex - 1;
                if (targetIndex < 0 || targetIndex >= sources.length) return;
                const source = sources[sourceIndex];
                const target = sources[targetIndex];
                const idx = state[source].findIndex((task) => task.id === id);
                if (idx < 0) return;
