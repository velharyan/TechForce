<section class="page-shell compact proex-page" data-product="@productKey">
    <div class="container">
        <nav class="breadcrumb"><a href="/">Home</a> / <a href="/Products">Produtos</a> / <span>@Model.Name</span></nav>

        <header class="proex-hero" data-reveal>
            <div class="proex-hero-head">
                <div>
                    <div class="proex-hero-mark">
                        <span class="proex-hero-icon">@Html.Raw(IconSvg(moduleIconKey))</span>
                        <p class="eyebrow">Demo profissional por modulo</p>
                    </div>
                    <h1>@Model.Name</h1>
                    <p>@Model.Summary</p>
                    <p class="proex-hero-note">@heroLabel</p>
                    <div class="proex-hero-tags">
                        @foreach (var tag in Model.Tags)
                        {
                            <span>@tag</span>
                        }
                    </div>
                </div>
                <div class="proex-hero-actions">
                    <a class="btn btn-primary" href="/Company/Contact">Quero este projeto na minha empresa</a>
                    <a class="btn btn-outline" href="@demoUrl" target="_blank" rel="noopener noreferrer">Dominio de referencia</a>
                </div>
            </div>
            <div class="proex-hero-stats">
                @foreach (var item in heroStats)
                {
                    <article>
                        <strong>@item.Value</strong>
                        <span>@item.Label</span>
                    </article>
                }
            </div>
        </header>

        <section class="info-strip" data-reveal>
            <article class="info-chip">
                <strong>Categoria</strong>
                <span>@Model.Category</span>
            </article>
            <article class="info-chip">
                <strong>Publico principal</strong>
                <span>@Model.Audience</span>
            </article>
            <article class="info-chip">
                <strong>Go-live inicial</strong>
                <span>@Model.StartingWeeks semana(s) para primeira entrega</span>
            </article>
        </section>

        <section class="proex-context-grid" data-reveal>
            @foreach (var item in contextCards)
            {
                <article class="card proex-context-card" data-hover-tilt>
                    <div class="proex-context-head">
                        <span class="proex-context-icon">@Html.Raw(IconSvg(item.Icon))</span>
                        <div>
                            <small>@item.Label</small>
                            <strong>@item.Value</strong>
                        </div>
                    </div>
                    <p>@item.Text</p>
                </article>
            }
        </section>

        <div class="proex-grid">
            <article class="card proex-demo" data-reveal>
                <div class="proex-browser">
                    <div class="proex-browser-top">
                        <div class="proex-dots" aria-hidden="true"><i></i><i></i><i></i></div>
                        <p class="proex-url">@demoUrl</p>
                        <span class="proex-env">homolog</span>
                    </div>

                    <section class="proex-app" id="proexApp" data-product="@productKey">
                        <header class="proex-header">
                            <div class="proex-brand">
                                <span class="proex-brand-dot" aria-hidden="true"></span>
                                <div>
                                    <strong>@Model.Name</strong>
                                    <small>Demo completo com menu e operacao real</small>
                                </div>
                            </div>

                            <nav class="proex-nav" aria-label="Menu interno do modulo">
                                <button class="active" type="button" data-view="overview">Visao geral</button>
                                <button type="button" data-view="operations">Operacao</button>
                                <button type="button" data-view="analytics">Analytics</button>
                                <button type="button" data-view="settings">Configuracoes</button>
                            </nav>

                            <div class="proex-actions">
                                <span class="proex-pill">producao-ready</span>
                                <button id="runPrimaryAction" class="proex-btn proex-btn-primary" type="button">Executar acao</button>
                            </div>
                        </header>

                        <main class="proex-main">
                            <section class="proex-view is-active" data-view-panel="overview"></section>
                            <section class="proex-view" data-view-panel="operations"></section>
                            <section class="proex-view" data-view-panel="analytics"></section>
                            <section class="proex-view" data-view-panel="settings"></section>
                        </main>

                        <footer class="proex-footer">
                            @foreach (var note in footerNotes)
                            {
                                <article>
                                    <h3>@note.Title</h3>
                                    <p>@note.Text</p>
                                </article>
                            }
                        </footer>
                    </section>
                </div>
            </article>

            <aside class="proex-sidebar" data-reveal>
                <section class="card proex-side-card">
                    <h2><span class="proex-side-icon">@Html.Raw(IconSvg("stack"))</span><span>Escopo de entrega</span></h2>
                    <ul class="proex-clean-list">
                        @foreach (var item in deliveryItems)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </section>

                <section class="card proex-side-card">
                    <h2><span class="proex-side-icon">@Html.Raw(IconSvg("shield"))</span><span>Arquitetura aplicada</span></h2>
                    <ul class="proex-clean-list">
                        @foreach (var item in architectureItems)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </section>

                <section class="card proex-side-card">
                    <h2><span class="proex-side-icon">@Html.Raw(IconSvg("rocket"))</span><span>Checklist de go-live</span></h2>
                    <ul class="proex-check-list">
                        <li><label><input type="checkbox" data-go-live checked /> Observabilidade ativa</label></li>
                        <li><label><input type="checkbox" data-go-live checked /> Perfil e permissao revisados</label></li>
                        <li><label><input type="checkbox" data-go-live /> Alertas de erro configurados</label></li>
                        <li><label><input type="checkbox" data-go-live /> Treinamento do time concluido</label></li>
                        <li><label><input type="checkbox" data-go-live /> Plano de rollback validado</label></li>
                    </ul>
                    <p id="goLiveProgress" class="proex-side-note"></p>
                    <button id="finishGoLive" class="btn btn-outline btn-block" type="button">Finalizar checklist automaticamente</button>
