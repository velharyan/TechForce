    .exm-bar-head {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        font-size: 0.72rem;
        color: #537193;
    }

    .proex-footer {
        border-top: 1px solid var(--line-soft);
        background: #f7faff;
        padding: 11px 13px;
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .proex-footer h3 {
        margin: 0 0 4px;
        font-size: 0.75rem;
    }

    .proex-footer p {
        margin: 0;
        color: var(--muted-ink);
        font-size: 0.7rem;
        line-height: 1.45;
    }

    .proex-sidebar {
        display: grid;
        gap: 10px;
        align-content: start;
        position: sticky;
        top: 106px;
        align-self: start;
    }

    .proex-side-card {
        display: grid;
        gap: 10px;
    }

    .proex-side-card h2 {
        margin: 0;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .proex-side-icon {
        width: 34px;
        height: 34px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--brand);
        background: rgba(55, 180, 230, 0.12);
        border: 1px solid rgba(55, 180, 230, 0.16);
    }

    .proex-side-icon svg {
        width: 16px;
        height: 16px;
    }

    .exm-card-head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .exm-card-icon {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        background: var(--accent-soft);
        border: 1px solid rgba(37, 139, 230, 0.12);
        flex: 0 0 auto;
    }

    .exm-card-icon svg {
        width: 15px;
        height: 15px;
    }

    .exm-card-head h3,
    .exm-card-head h4 {
        margin: 0;
    }

    .proex-clean-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 8px;
    }

    .proex-clean-list li {
        position: relative;
        padding-left: 15px;
        color: var(--muted);
        font-size: 0.9rem;
    }

    .proex-clean-list li::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: var(--brand);
        position: absolute;
        left: 0;
        top: 0.53em;
    }

    .proex-check-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 8px;
    }

    .proex-check-list label {
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.88rem;
        color: var(--muted);
    }

    .proex-check-list input {
        width: auto;
    }

    .proex-side-note {
        margin: 0;
        color: var(--muted);
        font-size: 0.84rem;
        font-weight: 700;
    }

    @@media (max-width: 1180px) {
        .proex-context-grid,
        .proex-grid {
            grid-template-columns: 1fr;
        }

        .proex-sidebar {
            position: static;
        }
    }

    @@media (max-width: 980px) {
        .proex-header {
            grid-template-columns: 1fr;
            align-items: flex-start;
        }

        .proex-nav {
            justify-content: flex-start;
            flex-wrap: nowrap;
            overflow-x: auto;
            padding-bottom: 4px;
            scrollbar-width: none;
        }

        .proex-nav::-webkit-scrollbar {
            display: none;
        }

        .proex-actions {
            width: 100%;
            justify-content: space-between;
        }

        .proex-footer,
        .exm-grid.two,
        .exm-grid.three,
        .exm-board,
        .exm-stats,
        .proex-hero-stats {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 760px) {
        .proex-hero-mark {
            align-items: flex-start;
        }

        .proex-hero-icon {
            width: 46px;
            height: 46px;
        }

        .proex-hero-actions {
            width: 100%;
        }

        .proex-hero-actions .btn {
            width: 100%;
        }

        .exm-form-row {
            grid-template-columns: 1fr;
        }

        .proex-browser-top {
            grid-template-columns: auto 1fr;
        }

        .proex-env {
            display: none;
        }

        .proex-actions {
            display: grid;
            gap: 8px;
            width: 100%;
        }

        .proex-pill,
        .proex-btn {
            width: 100%;
            text-align: center;
        }

        .exm-heatmap {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .proex-main {
            padding: 8px;
        }

        .proex-side-card,
        .proex-context-card {
            padding: 16px;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const app = document.getElementById("proexApp");
        if (!app) return;

        const productKey = app.getAttribute("data-product") || "erp-lite";
        const views = {
            overview: app.querySelector('[data-view-panel="overview"]'),
            operations: app.querySelector('[data-view-panel="operations"]'),
            analytics: app.querySelector('[data-view-panel="analytics"]'),
            settings: app.querySelector('[data-view-panel="settings"]')
        };

        const navButtons = Array.from(app.querySelectorAll("[data-view]"));
        const primaryActionButton = document.getElementById("runPrimaryAction");
        const goLiveBoxes = Array.from(document.querySelectorAll("[data-go-live]"));
        const goLiveProgress = document.getElementById("goLiveProgress");
        const goLiveFinish = document.getElementById("finishGoLive");

        const intFmt = new Intl.NumberFormat("pt-BR");
        const moneyFmt = new Intl.NumberFormat("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });
        const randomBetween = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;

        const statusClass = (status) => {
            const value = (status || "").toLowerCase();
            if (value.includes("ok") || value.includes("estavel") || value.includes("concl") || value.includes("resol")) return "ok";
            if (value.includes("crit") || value.includes("erro") || value.includes("falha") || value.includes("bloq")) return "err";
            if (value.includes("aten") || value.includes("pend") || value.includes("analise") || value.includes("esc")) return "warn";
            return "info";
        };

        const percent = (part, total) => total > 0 ? `${Math.round((part / total) * 100)}%` : "0%";
        const money = (value) => moneyFmt.format(value);
        const count = (value) => intFmt.format(value);

        const setView = (viewName) => {
            Object.keys(views).forEach((name) => {
                const panel = views[name];
                if (!panel) return;
                panel.classList.toggle("is-active", name === viewName);
            });
            navButtons.forEach((button) => {
                button.classList.toggle("active", button.getAttribute("data-view") === viewName);
            });
        };

        navButtons.forEach((button) => {
            button.addEventListener("click", () => {
                const viewName = button.getAttribute("data-view") || "overview";
                setView(viewName);
            });
        });

        const updateGoLive = () => {
            const done = goLiveBoxes.filter((box) => box.checked).length;
            if (goLiveProgress) goLiveProgress.textContent = `${done} de ${goLiveBoxes.length} itens concluidos`;
        };

        goLiveBoxes.forEach((box) => box.addEventListener("change", updateGoLive));
        goLiveFinish?.addEventListener("click", () => {
            goLiveBoxes.forEach((box) => {
                box.checked = true;
            });
            updateGoLive();
        });

        updateGoLive();

        const setPrimaryAction = (label, handler) => {
            if (!primaryActionButton) return;
            primaryActionButton.textContent = label;
            primaryActionButton.onclick = handler;
        };

        const renderBadge = (status) => `<span class="exm-badge ${statusClass(status)}">${status}</span>`;
        const renderLog = (logs, limit = 10) => `<ul class="exm-log">${logs.slice(0, limit).map((entry) => `<li>${entry}</li>`).join("")}</ul>`;

        const iconForTitle = (title) => {
            const value = (title || "").toLowerCase();
            if (/lead|funil|pipeline|campanha|marketing|comercial|cadencia/.test(value)) {
                return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8'><path d='M4 19h16'/><path d='M7 16V9'/><path d='M12 16V5'/><path d='M17 16v-4'/></svg>";
            }
            if (/estoque|pedido|checkout|catalogo|financeiro|erp/.test(value)) {
                return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8'><path d='M12 4l8 4-8 4-8-4 8-4z'/><path d='M4 12l8 4 8-4'/><path d='M4 16l8 4 8-4'/></svg>";
            }
            if (/app|mobile|equipe|rota|checklist/.test(value)) {
                return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8'><rect x='7' y='2.8' width='10' height='18.4' rx='2.3'/><path d='M10 5.5h4'/><circle cx='12' cy='17.8' r='0.9'/></svg>";
            }
            if (/kpi|dashboard|meta|tendencia|analytics|indicador/.test(value)) {
                return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8'><path d='M4 19h16'/><path d='M7 16V9'/><path d='M12 16V5'/><path d='M17 16v-4'/></svg>";
            }
            if (/workflow|fila|sla|retentativa|escalonamento|throughput/.test(value)) {
                return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8'><circle cx='6' cy='6' r='2.5'/><circle cx='18' cy='6' r='2.5'/><circle cx='12' cy='18' r='2.5'/><path d='M8.5 6h7'/><path d='M7.8 8.1l2.8 6.3'/><path d='M16.2 8.1l-2.8 6.3'/></svg>";
            }
            if (/segur|govern|api|gateway|portal|permiss|ticket/.test(value)) {
                return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8'><path d='M12 3l7 3v5c0 5-3 8.5-7 10-4-1.5-7-5-7-10V6l7-3z'/><path d='M9.5 12.2l1.8 1.8 3.4-3.8'/></svg>";
            }
            return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8'><rect x='4' y='4' width='16' height='16' rx='3'/></svg>";
        };

        const decoratePanels = () => {
            Object.values(views).forEach((panel) => {
                if (!(panel instanceof HTMLElement)) return;

                panel.querySelectorAll(".exm-card").forEach((card) => {
                    if (!(card instanceof HTMLElement)) return;
                    const heading = card.querySelector("h3, h4");
                    if (heading instanceof HTMLElement && !card.querySelector(".exm-card-head")) {
                        const head = document.createElement("div");
                        head.className = "exm-card-head";
                        const icon = document.createElement("span");
                        icon.className = "exm-card-icon";
                        icon.innerHTML = iconForTitle(heading.textContent || "");
                        heading.parentNode?.insertBefore(head, heading);
                        head.appendChild(icon);
                        head.appendChild(heading);
                    }

                    card.querySelectorAll(".exm-table").forEach((table) => {
                        if (!(table instanceof HTMLTableElement)) return;
                        if (table.parentElement?.classList.contains("exm-table-wrap")) return;
                        const wrap = document.createElement("div");
                        wrap.className = "exm-table-wrap";
                        table.parentNode?.insertBefore(wrap, table);
                        wrap.appendChild(table);
                    });
                });
            });
        };

        const panelObserver = "MutationObserver" in window
            ? new MutationObserver(() => decoratePanels())
            : null;

        Object.values(views).forEach((panel) => {
            if (panelObserver && panel instanceof HTMLElement) {
                panelObserver.observe(panel, { childList: true, subtree: true });
            }
        });

        const createSiteController = () => {
            const state = {
                visits: 6200,
                leads: 248,
                meetings: 64,
                wins: 22,
                responseSla: 15,
                seoScore: 87,
                pipeline: [
                    { company: "Grupo Atlas", channel: "Google Ads", budget: 58000, status: "Qualificado", owner: "Alice" },
                    { company: "Clinica Prime", channel: "SEO", budget: 41000, status: "Contato", owner: "Bruno" },
                    { company: "Rede Delta", channel: "Outbound", budget: 72000, status: "Novo", owner: "Carla" }
                ],
                channels: [
                    { name: "Google Ads", spend: 12600, leads: 122 },
                    { name: "SEO", spend: 2900, leads: 58 },
                    { name: "Meta Ads", spend: 7400, leads: 51 },
                    { name: "Outbound", spend: 4100, leads: 17 }
                ],
                pages: [
                    { name: "Home", conv: 3.8, dwell: "2m 18s", status: "ok" },
                    { name: "Cases", conv: 4.5, dwell: "3m 06s", status: "ok" },
                    { name: "Contato", conv: 2.2, dwell: "1m 11s", status: "warn" }
                ],
                logs: ["Site carregado com funil comercial inicial."]
            };

            const renderOverview = () => {
                views.overview.innerHTML = `
                    <section class="exm-stats">
                        <article class="exm-stat"><strong>${count(state.visits)}</strong><span>Visitas qualificadas</span></article>
                        <article class="exm-stat"><strong>${count(state.leads)}</strong><span>Leads</span></article>
                        <article class="exm-stat"><strong>${percent(state.meetings, state.leads)}</strong><span>Lead para reuniao</span></article>
                        <article class="exm-stat"><strong>${percent(state.wins, state.meetings)}</strong><span>Ganho comercial</span></article>
                    </section>
                    <section class="exm-grid two">
                        <article class="exm-card">
                            <h3>Funil institucional</h3>
                            <div class="exm-bar-row"><div class="exm-bar-head"><span>Visitas</span><strong>${count(state.visits)}</strong></div><div class="exm-progress"><i style="width:100%"></i></div></div>
                            <div class="exm-bar-row"><div class="exm-bar-head"><span>Leads</span><strong>${count(state.leads)}</strong></div><div class="exm-progress"><i style="width:${(state.leads / state.visits) * 100}%"></i></div></div>
                            <div class="exm-bar-row"><div class="exm-bar-head"><span>Reunioes</span><strong>${count(state.meetings)}</strong></div><div class="exm-progress"><i style="width:${(state.meetings / state.leads) * 100}%"></i></div></div>
                            <div class="exm-bar-row"><div class="exm-bar-head"><span>Fechamentos</span><strong>${count(state.wins)}</strong></div><div class="exm-progress"><i style="width:${(state.wins / state.meetings) * 100}%"></i></div></div>
                        </article>
                        <article class="exm-card">
                            <h3>Canal de aquisicao</h3>
                            <table class="exm-table">
                                <thead><tr><th>Canal</th><th>Leads</th><th>Invest.</th><th>CPL</th></tr></thead>
                                <tbody>
                                    ${state.channels.map((channel) => `<tr><td>${channel.name}</td><td>${count(channel.leads)}</td><td>${money(channel.spend)}</td><td>${money(Math.round(channel.spend / Math.max(1, channel.leads)))}</td></tr>`).join("")}
                                </tbody>
                            </table>
                        </article>
                    </section>
                `;
            };

            const renderOperations = () => {
                views.operations.innerHTML = `
                    <section class="exm-grid two">
                        <article class="exm-card">
                            <h3>Novo lead</h3>
                            <form id="siteLeadForm" class="exm-form">
                                <div class="exm-form-row">
                                    <input id="siteCompany" class="exm-input" placeholder="Empresa" required />
                                    <select id="siteChannel" class="exm-select">${state.channels.map((channel) => `<option>${channel.name}</option>`).join("")}</select>
                                </div>
                                <div class="exm-form-row">
                                    <input id="siteBudget" class="exm-input" type="number" min="5000" value="35000" />
                                    <input id="siteOwner" class="exm-input" placeholder="Responsavel" value="SDR Time" />
                                </div>
                                <div class="exm-actions">
                                    <button class="proex-btn proex-btn-primary" type="submit">Adicionar lead</button>
                                    <button class="proex-btn" type="button" id="siteAutoQualify">Qualificar top leads</button>
                                </div>
                            </form>
                        </article>
                        <article class="exm-card">
                            <h3>Pipeline</h3>
                            <table class="exm-table">
                                <thead><tr><th>Empresa</th><th>Canal</th><th>Status</th><th>Potencial</th></tr></thead>
                                <tbody>${state.pipeline.map((lead) => `<tr><td>${lead.company}</td><td>${lead.channel}</td><td>${renderBadge(lead.status)}</td><td>${money(lead.budget)}</td></tr>`).join("")}</tbody>
                            </table>
                        </article>
                    </section>
                `;

                views.operations.querySelector("#siteLeadForm")?.addEventListener("submit", (event) => {
                    event.preventDefault();
                    const companyInput = views.operations.querySelector("#siteCompany");
                    const channelInput = views.operations.querySelector("#siteChannel");
                    const budgetInput = views.operations.querySelector("#siteBudget");
                    const ownerInput = views.operations.querySelector("#siteOwner");
                    if (!(companyInput instanceof HTMLInputElement) || !(channelInput instanceof HTMLSelectElement) || !(budgetInput instanceof HTMLInputElement) || !(ownerInput instanceof HTMLInputElement)) return;
                    const company = companyInput.value.trim();
                    if (!company) return;
                    state.pipeline.unshift({ company, channel: channelInput.value, budget: Math.max(5000, Number(budgetInput.value || "0")), status: "Novo", owner: ownerInput.value.trim() || "SDR" });
                    state.leads += 1;
                    state.logs.unshift(`Lead adicionado: ${company}.`);
                    companyInput.value = "";
                    budgetInput.value = "35000";
                    renderAll();
                });

                views.operations.querySelector("#siteAutoQualify")?.addEventListener("click", () => {
                    let qualified = 0;
                    state.pipeline.forEach((lead) => {
                        if (lead.status === "Novo" && lead.budget >= 30000) {
                            lead.status = "Qualificado";
                            qualified += 1;
                        }
                    });
                    if (qualified > 0) {
                        state.meetings += qualified;
                        state.logs.unshift(`${qualified} lead(s) qualificados automaticamente.`);
                    }
                    renderAll();
                });
            };

            const renderAnalytics = () => {
                views.analytics.innerHTML = `
                    <section class="exm-grid two">
                        <article class="exm-card">
                            <h3>Performance de paginas</h3>
                            <table class="exm-table">
                                <thead><tr><th>Pagina</th><th>Conversao</th><th>Tempo</th><th>Status</th></tr></thead>
                                <tbody>${state.pages.map((page) => `<tr><td>${page.name}</td><td>${page.conv}%</td><td>${page.dwell}</td><td>${renderBadge(page.status)}</td></tr>`).join("")}</tbody>
                            </table>
                        </article>
                        <article class="exm-card">
                            <h3>Log de marketing</h3>
                            ${renderLog(state.logs)}
                        </article>
                    </section>
                `;
            };

            const renderSettings = () => {
                views.settings.innerHTML = `
                    <section class="exm-grid two">
                        <article class="exm-card">
                            <h3>Configuracoes</h3>
                            <ul class="exm-list">
                                <li><label><input id="siteSeo" type="checkbox" ${state.seoScore >= 80 ? "checked" : ""} /> SEO tecnico monitorado</label></li>
                                <li><label><input id="siteChat" type="checkbox" checked /> Chat de captura ativo</label></li>
                                <li><label><input id="siteAb" type="checkbox" /> Teste de headline em home</label></li>
                            </ul>
                        </article>
                        <article class="exm-card">
                            <h3>Parametros</h3>
                            <div class="exm-form">
                                <label>SLA de resposta comercial (${state.responseSla} min)</label>
                                <input id="siteSla" class="exm-range" type="range" min="5" max="45" value="${state.responseSla}" />
                                <label>Score de SEO (${state.seoScore})</label>
                                <input id="siteSeoScore" class="exm-range" type="range" min="60" max="100" value="${state.seoScore}" />
                                <button id="siteSaveConfig" class="proex-btn proex-btn-primary" type="button">Salvar configuracoes</button>
                            </div>
                        </article>
                    </section>
                `;

                views.settings.querySelector("#siteSaveConfig")?.addEventListener("click", () => {
                    const slaInput = views.settings.querySelector("#siteSla");
                    const scoreInput = views.settings.querySelector("#siteSeoScore");
                    if (!(slaInput instanceof HTMLInputElement) || !(scoreInput instanceof HTMLInputElement)) return;
                    state.responseSla = Number(slaInput.value);
                    state.seoScore = Number(scoreInput.value);
                    state.logs.unshift("Parametros de marketing salvos.");
                    renderAll();
                });
            };

            const runPrimary = () => {
                const extraVisits = randomBetween(240, 540);
                const extraLeads = randomBetween(16, 38);
                state.visits += extraVisits;
                state.leads += extraLeads;
                state.meetings += Math.max(2, Math.round(extraLeads * 0.25));
                state.wins += Math.max(1, Math.round(extraLeads * 0.08));
                state.logs.unshift(`Sprint comercial concluido: +${extraVisits} visitas e +${extraLeads} leads.`);
                renderAll();
            };

            const renderAll = () => {
                renderOverview();
                renderOperations();
                renderAnalytics();
                renderSettings();
            };

            return { primaryLabel: "Rodar sprint comercial", runPrimary, renderAll };
        };

        const createLandingController = () => {
            const state = {
                visitors: 8400,
                leads: 638,
                variants: [
                    { id: "v1", name: "Oferta A", headline: "Consultoria com diagnostico gratis", cta: "Quero analisar agora", conv: 7.2, cpa: 34, winner: false },
                    { id: "v2", name: "Oferta B", headline: "Projeto em 14 dias", cta: "Agendar reuniao", conv: 8.9, cpa: 27, winner: true },
                    { id: "v3", name: "Oferta C", headline: "Equipe senior dedicada", cta: "Receber proposta", conv: 6.3, cpa: 39, winner: false }
                ],
                channels: [
                    { name: "Google", spend: 14600, leads: 262 },
                    { name: "Meta", spend: 9200, leads: 219 },
                    { name: "LinkedIn", spend: 4800, leads: 81 },
                    { name: "Email", spend: 1200, leads: 76 }
                ],
                budgetSplit: { google: 45, meta: 30, linkedin: 20, email: 5 },
                heatmap: [1, 2, 2, 3, 4, 2, 1, 2, 3, 4, 3, 2],
                logs: ["Landing iniciada com experimento ativo."]
            };

            const bestVariant = () => state.variants.reduce((best, current) => current.conv > best.conv ? current : best, state.variants[0]);

            const renderOverview = () => {
                const winner = bestVariant();
                views.overview.innerHTML = `
                    <section class="exm-stats">
                        <article class="exm-stat"><strong>${count(state.visitors)}</strong><span>Visitas</span></article>
                        <article class="exm-stat"><strong>${count(state.leads)}</strong><span>Leads</span></article>
                        <article class="exm-stat"><strong>${percent(state.leads, state.visitors)}</strong><span>Conversao</span></article>
                        <article class="exm-stat"><strong>${winner.name}</strong><span>Melhor variacao</span></article>
                    </section>
                    <section class="exm-grid three">
                        ${state.variants.map((variant) => `
                            <article class="exm-card">
                                <h3>${variant.name} ${variant.winner ? '<span class="exm-badge ok">winner</span>' : ""}</h3>
                                <p>${variant.headline}</p>
