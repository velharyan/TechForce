                const costs = state.orders.reduce((sum, order) => {
                    const item = itemById(order.itemId);
                    return sum + (item ? item.cost * order.qty : 0);
                }, 0);
                const profit = sales() - costs;
                state.logs.unshift(`Fechamento diario: vendas ${money(sales())} | lucro ${money(profit)}.`);
                renderAll();
            };

            const renderAll = () => {
                renderOverview();
                renderOperations();
                renderAnalytics();
                renderSettings();
            };

            return { primaryLabel: "Rodar fechamento diario", runPrimary, renderAll };
        };

        const controllers = {
            site: createSiteController,
            landing: createLandingController,
            ecommerce: createEcommerceController,
            app: createAppController,
            api: createApiController,
            automation: createAutomationController,
            dashboard: createDashboardController,
        crm: createCrmController,
        ia: createAutomationController,
        portal: createPortalController,
        "erp-lite": createErpController
    };

        const controllerFactory = controllers[productKey] || createErpController;
        const controller = controllerFactory();
        setPrimaryAction(controller.primaryLabel, controller.runPrimary);
        controller.renderAll();
        decoratePanels();
        setView("overview");
    });
</script>
