@model IReadOnlyList<TechForce.Web.Controllers.ProductItem>
@{
    ViewData["Title"] = "Demos funcionais - TechForce";
    ViewData["Description"] = "Vitrine premium com demos funcionais de fluxo de caixa, site institucional, landing page, pagina de vendas, catalogo digital e cardapio digital.";
}

<section class="demos-page">
    <header class="demo-hero">
        <div class="container demo-hero-grid">
            <div data-reveal>
                <p class="eyebrow">Demos funcionais</p>
                <h1>Uma vitrine premium de produtos digitais reais, navegaveis e prontos para vender.</h1>
                <p>Cada experiencia usa dados mockados, interacao local e visual responsivo para demonstrar como um projeto pode chegar ao cliente final.</p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="#demoGrid">Explorar demos</a>
                    <button class="btn btn-outline" type="button" data-open-chat>Pedir recomendacao</button>
                </div>
            </div>
            <div class="demo-hero-preview" data-reveal data-delay="1" aria-hidden="true">
                <span class="preview-label">Live product preview</span>
                <div class="preview-stack">
                    <article><strong>Cash Flow</strong><span>R$ 84.320</span></article>
                    <article><strong>Catalogo</strong><span>24 produtos</span></article>
                    <article><strong>Cardapio</strong><span>R$ 136,70</span></article>
                </div>
            </div>
        </div>
    </header>

    <section class="section-band">
        <div class="container">
            <div class="demo-toolbar" data-reveal>
                <label class="sr-only" for="demoSearch">Buscar demo</label>
                <input id="demoSearch" type="search" placeholder="Buscar por produto, setor ou objetivo..." autocomplete="off" />
                <div class="demo-filter-group" aria-label="Filtros de demos">
                    <button class="demo-filter is-active" type="button" data-demo-filter="all">Todas</button>
                    <button class="demo-filter" type="button" data-demo-filter="saas">SaaS</button>
                    <button class="demo-filter" type="button" data-demo-filter="web">Web</button>
                    <button class="demo-filter" type="button" data-demo-filter="commerce">Comercial</button>
                    <button class="demo-filter" type="button" data-demo-filter="food">Food</button>
                </div>
            </div>

            <div id="demoGrid" class="demo-grid">
                <article class="demo-card" data-reveal data-demo-card data-demo="cashflow" data-category="saas" data-keywords="fluxo caixa financeiro dashboard saas transacoes graficos lucro">
                    <div class="demo-thumb cash-thumb"><span>R$</span><i></i><i></i><i></i></div>
                    <div class="demo-card-body">
                        <span class="demo-kicker">SaaS financeiro</span>
                        <h2>Aplicativo de Fluxo de Caixa</h2>
                        <p>Dashboard premium com saldo, entradas, saidas, lucro, grafico, tabela, filtros e nova transacao local.</p>
                        <div class="tag-row"><span>Dashboard</span><span>Filtros</span><span>Mock local</span></div>
                    </div>
                    <button class="btn btn-primary" type="button" data-open-demo="cashflow">Abrir demo</button>
                </article>

                <article class="demo-card" data-reveal data-delay="1" data-demo-card data-demo="institutional" data-category="web" data-keywords="site institucional empresa servicos sobre depoimentos cta">
                    <div class="demo-thumb site-thumb"><span>NovaHaus</span><strong></strong></div>
                    <div class="demo-card-body">
                        <span class="demo-kicker">Website premium</span>
                        <h2>Demo de Site Institucional</h2>
                        <p>Mini site com hero, servicos, sobre, depoimentos e CTA para empresa moderna.</p>
                        <div class="tag-row"><span>Hero</span><span>Servicos</span><span>Prova social</span></div>
                    </div>
                    <button class="btn btn-primary" type="button" data-open-demo="institutional">Abrir demo</button>
                </article>

                <article class="demo-card" data-reveal data-delay="2" data-demo-card data-demo="landing" data-category="web" data-keywords="landing page conversao formulario faq prova social campanha leads">
                    <div class="demo-thumb landing-thumb"><span>LeadOps</span><i></i></div>
                    <div class="demo-card-body">
                        <span class="demo-kicker">Alta conversao</span>
                        <h2>Demo de Landing Page</h2>
                        <p>Oferta forte, dor/solucao, beneficios, prova social, FAQ e formulario funcional.</p>
                        <div class="tag-row"><span>Leads</span><span>FAQ</span><span>Formulario</span></div>
                    </div>
                    <button class="btn btn-primary" type="button" data-open-demo="landing">Abrir demo</button>
                </article>

                <article class="demo-card" data-reveal data-demo-card data-demo="sales" data-category="commerce" data-keywords="site vendas pagina produto preco bonus garantia depoimentos checkout">
                    <div class="demo-thumb sales-thumb"><span>ScaleKit</span><strong>R$ 497</strong></div>
                    <div class="demo-card-body">
                        <span class="demo-kicker">Pagina de vendas</span>
                        <h2>Demo de Site de Vendas</h2>
                        <p>Produto ficticio com preco, beneficios, bonus, garantia, depoimentos e CTA persuasivo.</p>
                        <div class="tag-row"><span>Oferta</span><span>Garantia</span><span>CTA</span></div>
                    </div>
                    <button class="btn btn-primary" type="button" data-open-demo="sales">Abrir demo</button>
                </article>

                <article class="demo-card" data-reveal data-delay="1" data-demo-card data-demo="catalog" data-category="commerce" data-keywords="catalogo digital produtos categorias busca filtro preco botao">
                    <div class="demo-thumb catalog-thumb"><span>Catalogo</span><i></i><i></i><i></i><i></i></div>
                    <div class="demo-card-body">
                        <span class="demo-kicker">Catalogo digital</span>
                        <h2>Demo de Catalogo Digital</h2>
                        <p>Produtos ficticios com categorias, busca, filtros, cards, preco e acao comercial.</p>
                        <div class="tag-row"><span>Busca</span><span>Categoria</span><span>Produtos</span></div>
                    </div>
                    <button class="btn btn-primary" type="button" data-open-demo="catalog">Abrir demo</button>
                </article>

                <article class="demo-card" data-reveal data-delay="2" data-demo-card data-demo="menu" data-category="food" data-keywords="cardapio digital restaurante categorias carrinho total produtos preco imagem">
                    <div class="demo-thumb menu-thumb"><span>Bistro</span><strong>3 itens</strong></div>
                    <div class="demo-card-body">
                        <span class="demo-kicker">Restaurante</span>
                        <h2>Demo de Cardapio Digital</h2>
                        <p>Categorias, pratos, descricao, preco, imagens simuladas, carrinho simples e total.</p>
                        <div class="tag-row"><span>Pedidos</span><span>Carrinho</span><span>Mobile</span></div>
                    </div>
                    <button class="btn btn-primary" type="button" data-open-demo="menu">Abrir demo</button>
                </article>
            </div>
        </div>
    </section>
</section>

<div id="demoModal" class="demo-modal" hidden>
    <div class="demo-modal-backdrop" data-close-demo></div>
    <section class="demo-modal-panel" role="dialog" aria-modal="true" aria-labelledby="demoModalTitle">
        <header class="demo-modal-header">
            <div>
                <span id="demoModalKicker">Demo</span>
                <h2 id="demoModalTitle">Demo funcional</h2>
            </div>
            <button class="demo-close" type="button" data-close-demo aria-label="Fechar demo">Fechar</button>
        </header>
        <div id="demoModalBody" class="demo-modal-body"></div>
    </section>
</div>

@section Scripts {
    <script defer src="~/js/demos.js" asp-append-version="true"></script>
}
