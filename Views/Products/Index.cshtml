@using TechForce.Web.Controllers
@model IReadOnlyList<ProductItem>
@{
    var categories = Model
        .GroupBy(item => item.Category)
        .OrderBy(group => group.Key)
        .Select(group => new { Name = group.Key, Count = group.Count(), Items = group.ToList() })
        .ToList();

    var topIndicators = new[]
    {
        ("Demos ativos", $"{Model.Count} módulos", "demos"),
        ("Tempo médio inicial", "2 a 6 semanas", "weeks"),
        ("Cobertura", "10+ cenários reais", "scenarios"),
        ("Formato", "Web + Mobile + API", "format")
    };
}

<section class="page-shell compact module-page theme-software">
    <div class="container">
        <nav class="breadcrumb">
            <a href="/">Home</a> / <a href="/">Serviços</a> / <span>Demos por módulo</span>
        </nav>

        <header class="page-hero" data-reveal>
            <p class="eyebrow">Portfólio de demonstrações</p>
            <h1>Laboratório visual de soluções Tech Studio</h1>
            <p>Visualize experiências reais de operação, aquisição, dados e atendimento com aparência de produto pronto para produção.</p>
            <div class="hero-actions module-actions">
                <a class="btn btn-primary" href="/Company/Contact">Iniciar diagnóstico express</a>
                <a class="btn btn-outline" href="/Company/Chat">Abrir chat premium</a>
            </div>
        </header>

        <section class="info-strip" data-reveal>
            @foreach (var item in topIndicators)
            {
                <article class="info-chip">
                    <strong>@item.Item1</strong>
                    <span>@item.Item2</span>
                </article>
            }
        </section>

        <section class="module-layout">
            <article class="card module-card" data-reveal data-hover-tilt>
                <h2>Como usar este laboratório</h2>
                <p>Navegue por qualquer demo para abrir a experiência imersiva em modal. Cada ambiente mostra fluxo, indicadores e estado de operação com interface premium.</p>
                <ul class="list-clean">
                    <li><strong>1.</strong> Clique em “Ver demo” para abrir o simulador dentro do próprio site.</li>
                    <li><strong>2.</strong> Veja fluxo real de produto com painel, menus, ações e leitura de estados.</li>
                    <li><strong>3.</strong> Compare módulos e escolha o que combina com sua operação.</li>
                </ul>
                <div class="module-badges">
                    <span class="module-badge">Simulação realista</span>
                    <span class="module-badge">UX de produto</span>
                    <span class="module-badge">Escala arquitetural</span>
                </div>
            </article>

                <article class="card module-card" data-reveal data-delay="1">
                    <h2>Mapa de módulos por categoria</h2>
                    <p>Consolidados em uma trilha que cobre aquisição, operação, atendimento, integração e inteligência de negócio.</p>
                    <div class="module-kpis">
                        @foreach (var category in categories)
                        {
                        <article class="module-kpi">
                            <strong>@category.Count</strong>
                            <span>@category.Name</span>
                        </article>
                        }
                    </div>
            </article>
        </section>

        <section class="section-spaced">
            @foreach (var category in categories)
            {
                var anchor = $"cat-{(category.Name ?? "geral").ToLowerInvariant().Replace(" ", "-")}";
                <article class="card section-spaced" id="@anchor" data-reveal>
                    <h2>@category.Name</h2>
                    <p>Conjunto de ativos com foco em <strong>@(category.Name?.ToLowerInvariant())</strong>. Inicie pelo demo mais aderente ao seu objetivo atual.</p>
                    <div class="showcase-row">
                        @foreach (var item in category.Items)
                        {
                            var slug = item.Slug?.ToLowerInvariant() ?? "site";
                            var demoDevice = slug == "app" ? "mobile" : "web";
                            var badgeText = string.Join(" · ", item.Tags);
                            var details = $"{item.Audience} • entrega inicial {item.StartingWeeks} semana(s)";

                            @await Html.PartialAsync("_ShowcaseTile", new
                            {
                                Href = $"/Products/Example/{item.Slug}",
                                Title = item.Name,
                                Kicker = item.Category,
                                Description = item.Summary,
                                Details = $"{badgeText} | {details}",
                                Device = demoDevice
                            })
                        }
                    </div>
                </article>
            }
        </section>

        <section class="cta-panel section-spaced" data-reveal>
            <h2>Quer seu próprio dashboard premium em produção?</h2>
            <p>Montamos um conjunto de módulos para sua operação com roteiro, prazos e plano de implantação contínua.</p>
            <div class="module-actions">
                <a class="btn btn-primary" href="/Services">Ver soluções recomendadas</a>
                <a class="btn btn-outline" href="/Company/Contact">Quero proposta sob medida</a>
            </div>
        </section>
    </div>
</section>
