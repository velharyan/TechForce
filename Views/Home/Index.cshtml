@inject Microsoft.Extensions.Options.IOptions<AppOptions> App
@{
    var appOptions = App.Value;
    var companyName = string.IsNullOrWhiteSpace(appOptions.CompanyName) ? "TechForce" : appOptions.CompanyName;
    var normalizedWhatsApp = System.Text.RegularExpressions.Regex.Replace(appOptions.WhatsAppNumber ?? string.Empty, "[^0-9]", string.Empty);
    var contactHref = Url.Action("Contact", "Company") ?? "/Company/Contact";
    var specialistHref = string.IsNullOrWhiteSpace(normalizedWhatsApp) ? contactHref : $"https://wa.me/{normalizedWhatsApp}";
    var specialistIsExternal = !string.IsNullOrWhiteSpace(normalizedWhatsApp);
}

<section class="studio-home">
    <section class="hero-section" aria-labelledby="hero-title">
        <div class="container hero-grid">
            <div class="hero-copy" data-reveal>
                <p class="eyebrow">TechForce — Tecnologia sob medida</p>
                <h1 id="hero-title">Sites, sistemas e automações que multiplicam o seu negócio.</h1>
                <p class="hero-lead">
                    Criamos produtos digitais com foco em resultado: sites de alta conversão, sistemas sob medida,
                    automações inteligentes e catálogos digitais — tudo entregue em ciclos curtos, com código limpo
                    e estratégia de crescimento.
                </p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="@specialistHref" @(specialistIsExternal ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "")>
                        Solicitar diagnóstico
                    </a>
                    <a class="btn btn-outline" href="/Products">Ver demos funcionais</a>
                </div>
                <dl class="hero-metrics" aria-label="Indicadores de experiência">
                    <div><dt data-count-to="150" data-count-suffix="+">0</dt><dd>entregas digitais</dd></div>
                    <div><dt data-count-to="40" data-count-suffix="%">0</dt><dd>ganho operacional médio</dd></div>
                    <div><dt data-count-to="24" data-count-suffix="/7">0</dt><dd>base pronta para suporte</dd></div>
                </dl>
            </div>

            <div class="hero-product" data-reveal data-delay="1" aria-label="Preview de produto digital">
                <div class="product-window">
                    <div class="window-bar">
                        <span></span><span></span><span></span>
                        <strong>TechForce Command Center</strong>
                    </div>
                    <div class="command-grid">
                        <article class="command-card command-card-wide">
                            <span>Receita projetada</span>
                            <strong>R$ 428k</strong>
                            <div class="mini-chart" aria-hidden="true">
                                <i style="height:38%"></i><i style="height:56%"></i><i style="height:48%"></i><i style="height:72%"></i><i style="height:66%"></i><i style="height:88%"></i>
                            </div>
                        </article>
                        <article class="command-card">
                            <span>Leads qualificados</span>
                            <strong>218</strong>
                            <small>+32% no mês</small>
                        </article>
                        <article class="command-card">
                            <span>SLA médio</span>
                            <strong>12m</strong>
                            <small>atendimento priorizado</small>
                        </article>
                        <article class="workflow-card">
                            <div><span class="status-dot"></span><strong>Landing captou novo lead</strong></div>
                            <p>Bot qualificou projeto, criou card no CRM e notificou o comercial.</p>
                        </article>
                        <article class="workflow-card">
                            <div><span class="status-dot status-dot-warm"></span><strong>Pedido exigiu aprovação</strong></div>
                            <p>Automação abriu tarefa, anexou dados e atualizou o dashboard.</p>
                        </article>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-band" id="solucoes">
        <div class="container">
            <header class="section-heading" data-reveal>
                <p class="eyebrow">Soluções</p>
                <h2>Uma esteira completa: do zero ao digital.</h2>
                <p>Do primeiro contato até a entrega final, você tem acompanhamento estratégico, comunicação direta e transparência total na execução.</p>
            </header>
            <div class="service-grid">
                @await Html.PartialAsync("_Card", new { CardClass = "premium-card", Index = "01", Title = "Sites e landing pages", Body = "Performance, SEO e páginas de alta conversão.", DataRevealAttributes = "data-reveal data-hover-tilt" })
                @await Html.PartialAsync("_Card", new { CardClass = "premium-card", Index = "02", Title = "Sistemas e produtos SaaS", Body = "Software sob medida que organiza operações e escala processos.", DataRevealAttributes = "data-reveal data-delay=\"1\" data-hover-tilt" })
                @await Html.PartialAsync("_Card", new { CardClass = "premium-card", Index = "03", Title = "Automações e chatbots", Body = "Fluxos automáticos que triam, qualificam e conectam.", DataRevealAttributes = "data-reveal data-delay=\"2\" data-hover-tilt" })
                <article class="premium-card" data-reveal data-delay="3" data-hover-tilt>
                    <span class="card-index">04</span>
                    <h3>Catálogos e cardápios</h3>
                    <p>Catálogos filtráveis com busca, categorias e checkout simples.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="section-band split-section">
        <div class="container split-grid">
            <div data-reveal>
                <p class="eyebrow">Método</p>
                <h2>Arquitetura de produto, não de apenas telas bonitas.</h2>
                <p>Antes de escrever uma linha de código, mapeamos objetivos, público, fluxos e critérios de sucesso. Isso resulta em entregas mais rápidas, mais vendáveis e mais fáceis de evoluir.</p>
                <a class="btn btn-outline" href="/Services">Conhecer serviços</a>
            </div>
            <div class="process-list" data-reveal data-delay="1">
                <article><span>Diagnóstico</span><p>Entendimento do negócio, gargalos, dores e oportunidades comerciais com mapeamento completo.</p></article>
                <article><span>Protótipo premium</span><p>Visual, conteúdo e fluxo testados antes da entrega final com validação de usuário real.</p></article>
                <article><span>Implementação</span><p>Código limpo, responsivo, acessível e preparado para evoluir sem dívida técnica.</p></article>
                <article><span>Evolução contínua</span><p>Roadmap por impacto, métricas de negócio e melhoria contínua orientada a dados.</p></article>
            </div>
        </div>
    </section>

    <section class="section-band">
        <div class="container">
            <header class="section-heading" data-reveal>
                <p class="eyebrow">Demos</p>
                <h2>Veja demos reais antes de pedir uma proposta.</h2>
                <p>Toda a vitrine é interativa: clique, filtre, adicione itens e veja como o produto final se comporta. Sem surpresas no orçamento.</p>
            </header>
            <div class="showcase-row">
                @await Html.PartialAsync("_ShowcaseTile", new { Href = "/Products", Title = "Fluxo de caixa SaaS", Description = "Dashboard, transações, filtros e gráficos em tempo real.", DataRevealAttributes = "data-reveal" })
                @await Html.PartialAsync("_ShowcaseTile", new { Href = "/Products", Title = "Landing de conversão", Description = "Oferta, prova social, FAQ e formulário com validação local.", DataRevealAttributes = "data-reveal data-delay=\"1\"" })
                <a class="showcase-tile" href="/Products" data-reveal data-delay="2">
                    <strong>Cardápio digital</strong>
                    <span>Categorias, itens, carrinho e fechamento simulados.</span>
                    <span class="tile-link">Ver demo &rarr;</span>
                </a>
            </div>
        </div>
    </section>

    <section class="section-band final-cta">
        <div class="container">
            <div class="cta-panel" data-reveal>
                <p class="eyebrow">@companyName</p>
                <h2>Vamos transformar sua ideia em produto digital?</h2>
                <p>Orçamento sem compromisso em 24h. Proposta com escopo, prazo e investimento.</p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="@contactHref">Solicitar proposta</a>
                    <button class="btn btn-outline" type="button" data-open-chat>Falar com assistente</button>
                </div>
            </div>
        </div>
    </section>
</section>