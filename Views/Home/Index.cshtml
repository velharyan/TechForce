@inject Microsoft.Extensions.Options.IOptions<AppOptions> App
@{
    var appOptions = App.Value;
    var contactHref = Url.Action("Contact", "Company") ?? "/Company/Contact";
}

<section class="studio-home">
    <section class="hero-section section-band" aria-labelledby="homeHero">
        <div class="container hero-grid">
            <div class="hero-copy" data-reveal>
                <p class="eyebrow">Tech Studio</p>
                <h1 id="homeHero">
                    Uma companhia de tecnologia que entrega sistemas que vendem, escalam e convertem.
                </h1>
                <p class="hero-lead">
                    Projetamos ecossistemas digitais para operação e crescimento: produto, automacao, dados e atendimento.
                    Tudo com execução de verdade, sem prototipos estereotipados.
                </p>
                <div class="hero-actions">
                    <button class="btn btn-primary" type="button" data-open-chat>Comecar por consultoria premium</button>
                    <a href="/Services" class="btn btn-outline">Entender abordagem de execucao</a>
                </div>
                <div class="hero-metrics">
                    <div>
                        <dt data-count-to="140">0</dt>
                        <dd>Projetos com impacto operacional</dd>
                    </div>
                    <div>
                        <dt data-count-to="92">0</dt>
                        <dd>% de satisfacao media dos clientes</dd>
                    </div>
                    <div>
                        <dt data-count-to="5">0</dt>
                        <dd>Semanas para primeira entrega com valor</dd>
                    </div>
                </div>
            </div>

            <div class="hero-product" data-reveal data-delay="1" aria-label="Painel de comando">
                <article class="command-center">
                    <header class="command-center-head">
                        <div>
                            <strong class="command-head-title">Command Center</strong>
                        </div>
                        <div>
                            <span class="command-control"></span>
                            <span class="command-control"></span>
                            <span class="command-control"></span>
                        </div>
                    </header>

                    <div class="command-grid">
                        <article class="command-card command-card-big">
                            <h3>Decisao com previsibilidade</h3>
                            <p>R$ 1,8M</p>
                            <div class="command-chart" aria-hidden="true">
                                <i style="height:34%"></i><i style="height:52%"></i><i style="height:70%"></i><i style="height:78%"></i><i style="height:89%"></i><i style="height:98%"></i>
                            </div>
                        </article>

                        <article class="command-card">
                            <h3>Demandas em tempo real</h3>
                            <p>284</p>
                        </article>

                        <article class="command-card">
                            <h3>Tempo de resposta</h3>
                            <p>11 min</p>
                        </article>

                        <article class="command-card">
                            <h3>Status da trilha</h3>
                            <p>Roteamento ativo</p>
                        </article>

                        <article class="command-card">
                            <h3>Execucao</h3>
                            <p>Pronta para sprint</p>
                        </article>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section class="section-band" id="solucoes">
        <div class="container">
            <header class="section-heading" data-reveal>
                <p class="eyebrow">Tecnologia com cara de empresa real</p>
                <h2>Arquitetura orientada a decisao, nao a tela bonita.</h2>
                <p>Construimos produtos que encaixam no fluxo operacional, reduzem risco e aceleram receita. Cada semana vira um ciclo de valor real com mensageria e observabilidade.</p>
            </header>

            <div class="service-grid">
                @await Html.PartialAsync("_Card", new
                {
                    CardClass = "premium-card",
                    Index = "01",
                    Delay = "1",
                    Eyebrow = "Descoberta",
                    Title = "Diagnostico tecnico e comercial",
                    Body = "Mapeamos gargalos, metas e prioridade de negocio para criar um plano com impacto real.",
                    Bullets = new[] { "Mapeamento da demanda", "Definicao de ganho por sprint", "Modelo de risco e execucao" }
                })
                @await Html.PartialAsync("_Card", new
                {
                    CardClass = "premium-card",
                    Index = "02",
                    Delay = "2",
                    Eyebrow = "Arquitetura",
                    Title = "Implementacao orientada por dado",
                    Body = "Integramos produto, automacao e atendimento para gerar uma base decisoria operacionalmente confiavel.",
                    Bullets = new[] { "Camadas rastreaveis", "Governanca", "Observabilidade de ponta a ponta" }
                })
                @await Html.PartialAsync("_Card", new
                {
                    CardClass = "premium-card",
                    Index = "03",
                    Delay = "3",
                    Eyebrow = "Escala",
                    Title = "Entrega com previsibilidade",
                    Body = "Iteramos em ciclos curtos com metas comerciais claras para evoluir sem interromper operação.",
                    Bullets = new[] { "Plano quinzenal", "Qualidade de rollout", "Maturacao tecnica gradual" }
                })
                @await Html.PartialAsync("_Card", new
                {
                    CardClass = "premium-card",
                    Index = "04",
                    Delay = "4",
                    Eyebrow = "Evidencia",
                    Title = "Comunicacao executiva e premium",
                    Body = "Relatorios, metricas e roadmap com linguagem de direcao para manter alinhamento e decisao.",
                    Bullets = new[] { "Ritos executivos", "Dashboard de risco", "Acoes imediatas e metas semanais" }
                })
            </div>
        </div>
    </section>

    <section class="section-band">
        <div class="container split-grid">
            <div data-reveal>
                <p class="eyebrow">Metodo</p>
                <h2>Metodo de entregas com rigor operacional.</h2>
                <p>Na primeira semana mapeamos contexto real. Na segunda implantamos o esqueleto funcional. Nos ciclos seguintes, medimos, iteramos e escalamos.</p>
                <a href="/Services" class="btn btn-outline">Ver escopo de servicos</a>
            </div>
            <div class="process-list" data-reveal data-delay="1">
                <article>
                    <span>Semana 1</span>
                    <p>Mapeamento de gargalo com fluxo atual, metas e primeiro prototipo funcional.</p>
                </article>
                <article>
                    <span>Semana 2</span>
                    <p>Arquitetura viva para venda, atendimento e operacao com metrica de risco ativa.</p>
                </article>
                <article>
                    <span>Semana 3</span>
                    <p>Automacoes de ponta a ponta, reducao de retrabalho e melhoria de SLA.</p>
                </article>
                <article>
                    <span>Semana 4</span>
                    <p>Piloto com leitura de negocio, ajuste executivo e plano de evolucao.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="section-band" id="demos">
        <div class="container">
            <header class="section-heading" data-reveal>
                <p class="eyebrow">Demos reais</p>
                <h2>Demonstracoes hiper-realistas de ambientes comerciais e operacionais.</h2>
                <p>Abra qualquer demo em uma experiencia integrada com janela de navegador simulada, 90% de tela e foco total em contexto de producao.</p>
            </header>
            <div class="showcase-row">
                @await Html.PartialAsync("_ShowcaseTile", new
                {
                    Href = "/Products/Example/site",
                    Title = "Site institucional de conversao",
                    Kicker = "Comercial",
                    Description = "Pagina estrategica com trilha de lead e rastreabilidade de origem.",
                    Details = "Otimo para acelerar aquisicao com consistencia.",
                    Device = "web"
                })
                @await Html.PartialAsync("_ShowcaseTile", new
                {
                    Href = "/Products/Example/dashboard",
                    Title = "Painel executivo de performance",
                    Kicker = "Dados",
                    Description = "Indicadores por risco, tendencia e janela de decisao para lideranca.",
                    Details = "Apoia reunioes semanais com leitura critica.",
                    Device = "web"
                })
                @await Html.PartialAsync("_ShowcaseTile", new
                {
                    Href = "/Products/Example/ia",
                    Title = "Assistente inteligente operacional",
                    Kicker = "Atendimento",
                    Description = "Fila priorizada, resposta em segundos e encaminhamento consultivo.",
                    Details = "Experiencia escalavel para times com SLA exigente.",
                    Device = "web"
                })
            </div>
        </div>
    </section>

    <section class="section-band" id="contato">
        <div class="container">
            <article class="cta-panel" data-reveal>
                <p class="eyebrow">@appOptions.CompanyName</p>
                <h2>Pronto para evoluir tecnologia em decisao e crescimento?</h2>
                <p>Iniciamos com uma descoberta operacao, mapeamos risco e entregamos uma estrutura com valor visivel nas primeiras 30 dias.</p>
                <div class="hero-actions">
                    <a href="@contactHref" class="btn btn-primary">Agendar contato executivo</a>
                    <button class="btn btn-outline" type="button" data-open-chat>Falar com assistente agora</button>
                </div>
            </article>
        </div>
    </section>
</section>
