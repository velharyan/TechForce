@inject Microsoft.Extensions.Options.IOptions<AppOptions> App
@{
    var appOptions = App.Value;
    var companyName = string.IsNullOrWhiteSpace(appOptions.CompanyName) ? "TechForce" : appOptions.CompanyName;
    var normalizedWhatsApp = System.Text.RegularExpressions.Regex.Replace(appOptions.WhatsAppNumber ?? string.Empty, "[^0-9]", string.Empty);
    var contactHref = Url.Action("Contact", "Company") ?? "/Company/Contact";
    var specialistHref = string.IsNullOrWhiteSpace(normalizedWhatsApp) ? contactHref : $"https://wa.me/{normalizedWhatsApp}";
    var specialistIsExternal = !string.IsNullOrWhiteSpace(normalizedWhatsApp);
}

<section class="studio-home">
    <section class="hero-section" aria-labelledby="hero-title">
        <div class="container hero-grid">
            <div class="hero-copy" data-reveal>
                <p class="eyebrow">Tech studio para empresas que precisam vender e operar melhor</p>
                <h1 id="hero-title">Produtos digitais premium para transformar operacao em crescimento.</h1>
                <p class="hero-lead">
                    Criamos sites, sistemas, automacoes, landing pages, catalogos, cardapios digitais,
                    chatbots e plataformas sob medida com acabamento comercial, performance e escala.
                </p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="@specialistHref" @(specialistIsExternal ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "")>
                        Solicitar diagnostico
                    </a>
                    <a class="btn btn-outline" href="/Products">Ver demos funcionais</a>
                </div>
                <dl class="hero-metrics" aria-label="Indicadores de experiencia">
                    <div><dt data-count-to="150" data-count-suffix="+">0</dt><dd>entregas digitais</dd></div>
                    <div><dt data-count-to="40" data-count-suffix="%">0</dt><dd>ganho operacional medio</dd></div>
                    <div><dt data-count-to="24" data-count-suffix="/7">0</dt><dd>base pronta para suporte</dd></div>
                </dl>
            </div>

            <div class="hero-product" data-reveal data-delay="1" aria-label="Preview de produto digital">
                <div class="product-window">
                    <div class="window-bar">
                        <span></span><span></span><span></span>
                        <strong>NexCore Command Center</strong>
                    </div>
                    <div class="command-grid">
                        <article class="command-card command-card-wide">
                            <span>Receita projetada</span>
                            <strong>R$ 428k</strong>
                            <div class="mini-chart" aria-hidden="true">
                                <i style="height:38%"></i><i style="height:56%"></i><i style="height:48%"></i><i style="height:72%"></i><i style="height:66%"></i><i style="height:88%"></i>
                            </div>
                        </article>
                        <article class="command-card">
                            <span>Leads qualificados</span>
                            <strong>218</strong>
                            <small>+32% no mes</small>
                        </article>
                        <article class="command-card">
                            <span>SLA medio</span>
                            <strong>12m</strong>
                            <small>atendimento priorizado</small>
                        </article>
                        <article class="workflow-card">
                            <div><span class="status-dot"></span><strong>Landing captou novo lead</strong></div>
                            <p>Bot qualificou projeto, criou card no CRM e notificou o comercial.</p>
                        </article>
                        <article class="workflow-card">
                            <div><span class="status-dot status-dot-warm"></span><strong>Pedido exigiu aprovacao</strong></div>
                            <p>Automacao abriu tarefa, anexou dados e atualizou o dashboard.</p>
                        </article>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-band" id="solucoes">
        <div class="container">
            <header class="section-heading" data-reveal>
                <p class="eyebrow">Solucoes</p>
                <h2>Uma esteira completa para presenca digital, operacao e vendas.</h2>
                <p>Combinamos design, engenharia e estrategia comercial para entregar experiencias que parecem prontas para cliente real desde o primeiro contato.</p>
            </header>
            <div class="service-grid">
                <article class="premium-card" data-reveal data-hover-tilt>
                    <span class="card-index">01</span>
                    <h3>Sites e landing pages</h3>
                    <p>Narrativa, SEO tecnico, performance mobile e paginas de conversao para captar oportunidades.</p>
                    <ul><li>Institucional premium</li><li>Landing de campanha</li><li>Pagina de vendas</li></ul>
                </article>
                <article class="premium-card" data-reveal data-delay="1" data-hover-tilt>
                    <span class="card-index">02</span>
                    <h3>Sistemas e produtos SaaS</h3>
                    <p>Dashboards, CRMs, portais e softwares sob medida para organizar rotinas e dados.</p>
                    <ul><li>Fluxos financeiros</li><li>Perfis e permissoes</li><li>Relatorios executivos</li></ul>
                </article>
                <article class="premium-card" data-reveal data-delay="2" data-hover-tilt>
                    <span class="card-index">03</span>
                    <h3>Automacoes e chatbots</h3>
                    <p>Atendimento, triagem, backoffice e integracoes que reduzem tarefas manuais.</p>
                    <ul><li>WhatsApp e CRM</li><li>Regras de SLA</li><li>Base de conhecimento</li></ul>
                </article>
                <article class="premium-card" data-reveal data-delay="3" data-hover-tilt>
                    <span class="card-index">04</span>
                    <h3>Catalogos e cardapios digitais</h3>
                    <p>Experiencias comerciais bonitas, filtraveis e prontas para apresentar produtos.</p>
                    <ul><li>Busca e categorias</li><li>Carrinho simples</li><li>CTA comercial</li></ul>
                </article>
            </div>
        </div>
    </section>

    <section class="section-band split-section">
        <div class="container split-grid">
            <div data-reveal>
                <p class="eyebrow">Metodo</p>
                <h2>Arquitetura de produto, nao apenas telas bonitas.</h2>
                <p>Antes de codar, definimos objetivo, publico, fluxo, dados, integracoes e criterio de sucesso. O resultado fica mais claro, mais vendavel e mais facil de evoluir.</p>
                <a class="btn btn-outline" href="/Services">Conhecer servicos</a>
            </div>
            <div class="process-list" data-reveal data-delay="1">
                <article><span>Diagnostico</span><p>Entendimento do negocio, gargalos, dores e oportunidades comerciais.</p></article>
                <article><span>Prototipo premium</span><p>Visual, conteudo e fluxo testados antes da entrega final.</p></article>
                <article><span>Implementacao</span><p>Codigo limpo, responsivo, acessivel e preparado para evoluir.</p></article>
                <article><span>Evolucao</span><p>Roadmap por impacto, metricas e melhoria continua.</p></article>
            </div>
        </div>
    </section>

    <section class="section-band">
        <div class="container">
            <header class="section-heading" data-reveal>
                <p class="eyebrow">Demos</p>
                <h2>Veja exemplos navegaveis antes de pedir uma proposta.</h2>
                <p>A vitrine de demos mostra dashboards, paginas comerciais, catalogos e cardapios com interacao real usando dados mockados.</p>
            </header>
            <div class="showcase-row">
                <a class="showcase-tile" href="/Products" data-reveal>
                    <strong>Fluxo de caixa SaaS</strong>
                    <span>Dashboard, transacoes, filtros e graficos.</span>
                </a>
                <a class="showcase-tile" href="/Products" data-reveal data-delay="1">
                    <strong>Landing de conversao</strong>
                    <span>Oferta, prova social, FAQ e formulario.</span>
                </a>
                <a class="showcase-tile" href="/Products" data-reveal data-delay="2">
                    <strong>Cardapio digital</strong>
                    <span>Categorias, itens, carrinho e total.</span>
                </a>
            </div>
        </div>
    </section>

    <section class="section-band final-cta">
        <div class="container">
            <div class="cta-panel" data-reveal>
                <p class="eyebrow">@companyName</p>
                <h2>Vamos transformar sua ideia em um produto digital com presenca de marca grande.</h2>
                <p>Conte seu objetivo e receba um plano inicial com escopo, prioridade e caminho recomendado.</p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="@contactHref">Solicitar proposta</a>
                    <button class="btn btn-outline" type="button" data-open-chat>Falar com assistente</button>
                </div>
            </div>
        </div>
    </section>
</section>
