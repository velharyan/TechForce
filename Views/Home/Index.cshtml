<script>
    document.addEventListener("DOMContentLoaded", function () {
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reducedMotion) return;

        const feedItems = Array.from(document.querySelectorAll("[data-home-log]"));
        const barA = document.getElementById("homeBarA");
        const barB = document.getElementById("homeBarB");
        const barValueA = document.getElementById("homeBarValueA");
        const barValueB = document.getElementById("homeBarValueB");
        const states = [{ a: 68, b: 74 }, { a: 72, b: 79 }, { a: 76, b: 82 }, { a: 81, b: 87 }];
        let index = 0;

        window.setInterval(function () {
            if (feedItems.length > 0) {
                feedItems.forEach(function (item, itemIndex) {
                    item.classList.toggle("is-active", itemIndex === index % feedItems.length);
                });
            }

            const state = states[index % states.length];
            if (barA) barA.style.setProperty("--width", state.a + "%");
            if (barB) barB.style.setProperty("--width", state.b + "%");
            if (barValueA) barValueA.textContent = state.a + "%";
            if (barValueB) barValueB.textContent = state.b + "%";
            index += 1;
        }, 2600);
    });
</script>
