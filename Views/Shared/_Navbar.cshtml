@* Navbar parcial premium *@
@using Microsoft.Extensions.Options
@inject IOptions<AppOptions> App
@{
    var app = App.Value;
    var normalizedWhatsApp = System.Text.RegularExpressions.Regex.Replace(app.WhatsAppNumber ?? string.Empty, "[^0-9]", string.Empty);
    var whatsappHref = string.IsNullOrWhiteSpace(normalizedWhatsApp) ? null : $"https://wa.me/{normalizedWhatsApp}";
    var path = Context?.Request?.Path.Value?.ToLowerInvariant() ?? "/";
    var current = path.TrimEnd('/').ToLowerInvariant();

    var nav = new[]
    {
        (Href: "/", Text: "Início", IsCta: false),
        (Href: "/Services", Text: "Soluções", IsCta: false),
        (Href: "/Products", Text: "Demos", IsCta: false),
        (Href: "/Cases", Text: "Cases", IsCta: false),
        (Href: "/Testimonials", Text: "Resultados", IsCta: false),
        (Href: "/Company/Contact", Text: "Contato", IsCta: true)
    };
}

<header class="site-header" id="mainHeader" role="banner">
    <div class="container header-inner">
        <a class="brand" href="/" aria-label="Ir para início">
            <img src="~/img/logo3.png" asp-append-version="true" alt="@app.CompanyName" />
            <span class="brand-lockup">
                <strong class="brand-name">@app.CompanyName</strong>
                <small class="brand-subtitle">@app.Tagline</small>
            </span>
        </a>

        <nav class="desktop-nav" aria-label="Navegação principal">
            @foreach (var item in nav)
            {
                var active = current == item.Href.ToLowerInvariant() || (item.Href != "/" && current.StartsWith(item.Href.ToLowerInvariant(), StringComparison.InvariantCultureIgnoreCase));
                if (item.IsCta)
                {
                    <a href="@item.Href" class="btn btn-primary nav-cta" aria-current="@(active ? "page" : null)">@item.Text</a>
                }
                else
                {
                    <a href="@item.Href" class="nav-link" aria-current="@(active ? "page" : null)">@item.Text</a>
                }
            }
        </nav>

        <div class="header-actions">
            <button id="themeToggle" class="theme-toggle" type="button" aria-label="Alternar tema">
                <span aria-hidden="true">&#x2600;</span>
                <span class="sr-only">Alternar tema</span>
            </button>
            <button id="menuToggle" class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobileNav" aria-label="Abrir menu">
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
            </button>
        </div>
    </div>

    <nav id="mobileNav" class="mobile-nav" aria-label="Navegacao mobile" hidden>
        <div class="mobile-nav-inner">
            <div class="mobile-nav-head">
                <span>Menu</span>
                <button id="themeToggleMobile" class="theme-toggle" type="button" aria-label="Alternar tema mobile">
                    <span aria-hidden="true">&#x2600;</span>
                    <span class="sr-only">Alternar tema</span>
                </button>
            </div>
            @foreach (var item in nav)
            {
                var active = current == item.Href.ToLowerInvariant() || (item.Href != "/" && current.StartsWith(item.Href.ToLowerInvariant(), StringComparison.InvariantCultureIgnoreCase));
                <a href="@item.Href" class="@(item.IsCta ? "btn btn-primary" : "mobile-link")" aria-current="@(active ? "page" : null)">@item.Text</a>
            }
            @if (!string.IsNullOrWhiteSpace(whatsappHref))
            {
                <a class="mobile-link" href="@whatsappHref" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            }
        </div>
    </nav>
</header>
<button id="mobileNavBackdrop" class="mobile-nav-backdrop" type="button" hidden aria-label="Fechar menu"></button>
