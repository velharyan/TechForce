@using Microsoft.Extensions.Options
@inject IOptions<AppOptions> AppOptions
@inject IOptions<SeoOptions> SeoOptions
@inject IOptions<AnalyticsOptions> AnalyticsOptions
@{
    var app = AppOptions.Value;
    var seo = SeoOptions.Value;
    var title = ViewData["Title"] as string ?? seo.DefaultTitle;
    var description = ViewData["Description"] as string ?? seo.DefaultDescription;
    var path = (Context?.Request?.Path.Value ?? "/").ToLowerInvariant();
    var pathSegments = path.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
    var sectionKey = pathSegments.Length > 0 ? pathSegments[0] : "home";
    var pageKey = pathSegments.Length > 1 ? $"{sectionKey}-{pathSegments[1]}" : sectionKey;
    var baseUrl = seo.BaseUrl?.TrimEnd('/');
    var canonical = !string.IsNullOrWhiteSpace(baseUrl) ? $"{baseUrl}{Context?.Request?.Path.Value}" : null;
    var ogImage = !string.IsNullOrWhiteSpace(seo.OgImage) ? seo.OgImage : Url.Content("~/img/og-default.png");

    var nav = new (string href, string text, bool cta)[] {
        ("/", "Home", false),
        ("/Services", "Servicos", false),
        ("/Products", "Demos", false),
        ("/Cases", "Cases", false),
        ("/Testimonials", "Depoimentos", false),
        ("/Blog", "Blog", false),
        ("/Company/About", "Sobre", false),
        ("/Company/Contact", "Falar com time", true)
    };

    Func<string, bool> isActive = href =>
    {
        var lower = href.ToLowerInvariant();
        return lower == "/" ? path == "/" : path.StartsWith(lower);
    };

    var normalizedWhatsApp = System.Text.RegularExpressions.Regex.Replace(app.WhatsAppNumber ?? string.Empty, "[^0-9]", string.Empty);
    var whatsappHref = string.IsNullOrWhiteSpace(normalizedWhatsApp) ? null : $"https://wa.me/{normalizedWhatsApp}";
}
<!DOCTYPE html>
<html lang="pt-BR" class="no-js" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <title>@title</title>
    <meta name="description" content="@description" />
    @if (!string.IsNullOrWhiteSpace(canonical))
    {
        <link rel="canonical" href="@canonical" />
    }
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@title" />
    <meta property="og:description" content="@description" />
    @if (!string.IsNullOrWhiteSpace(canonical))
    {
        <meta property="og:url" content="@canonical" />
    }
    <meta property="og:image" content="@ogImage" />
    <meta name="theme-color" content="#0a162d" />
    <script>
        (function () {
            try {
                var savedTheme = localStorage.getItem("nxc_theme");
                if (savedTheme === "dark" || savedTheme === "light") {
                    document.documentElement.setAttribute("data-theme", savedTheme);
                }
            } catch (error) {
                /* no-op */
            }
        })();
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body data-section="@sectionKey" data-page="@pageKey">
    <a class="skip-link" href="#conteudo">Ir para o conteudo principal</a>
    <div id="scrollProgress" class="scroll-progress" aria-hidden="true"></div>
    <div class="bg-glow bg-glow-a" aria-hidden="true"></div>
    <div class="bg-glow bg-glow-b" aria-hidden="true"></div>

    <header class="site-header" id="mainHeader" role="banner">
        <div class="container header-inner">
            <a class="brand" href="/" aria-label="Ir para Home">
                <img src="~/img/logo3.png" asp-append-version="true" alt="@app.CompanyName" />
                <span class="brand-lockup">
                    <strong class="brand-name">@app.CompanyName</strong>
                    <small class="brand-subtitle">Digital products e automacao</small>
                </span>
            </a>

            <nav class="desktop-nav" aria-label="Navegacao principal">
                @foreach (var item in nav)
                {
                    var active = isActive(item.href);
                    <a href="@item.href" class="@(item.cta ? "btn btn-primary nav-cta" : "nav-link")" aria-current="@(active ? "page" : null)">@item.text</a>
                }
            </nav>

            <div class="header-actions">
                <button id="themeToggle" class="theme-toggle" type="button" aria-label="Alternar tema">Tema</button>
                <button id="menuToggle" class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobileNav" aria-label="Abrir menu">Menu</button>
            </div>
        </div>

        <nav id="mobileNav" class="mobile-nav" aria-label="Navegacao mobile" hidden>
            <div class="mobile-nav-inner">
                <div class="mobile-nav-head">
                    <span>Navegacao</span>
                    <button id="themeToggleMobile" class="theme-toggle" type="button" aria-label="Alternar tema mobile">Tema</button>
                </div>
                @foreach (var item in nav)
                {
                    var active = isActive(item.href);
                    <a href="@item.href" class="@(item.cta ? "btn btn-primary" : "mobile-link")" aria-current="@(active ? "page" : null)">@item.text</a>
                }
            </div>
        </nav>
    </header>
    <button id="mobileNavBackdrop" class="mobile-nav-backdrop" type="button" hidden aria-label="Fechar menu"></button>

    <main id="conteudo" class="site-main" role="main" tabindex="-1">
        @RenderBody()
    </main>

    <footer class="site-footer" role="contentinfo">
        <div class="container footer-grid">
            <section class="footer-brand">
                <a class="brand footer-logo" href="/" aria-label="Ir para Home">
                    <img src="~/img/logo3.png" asp-append-version="true" alt="@app.CompanyName" />
                    <span>@app.CompanyName</span>
                </a>
                <p>@(string.IsNullOrWhiteSpace(app.Tagline) ? "Solucoes digitais com foco em resultado, escala e confianca operacional." : app.Tagline)</p>
            </section>

            <section>
                <h2 class="footer-title">Empresa</h2>
                <ul class="footer-links">
                    <li><a href="/Company/About">Sobre</a></li>
                    <li><a href="/Cases">Cases</a></li>
                    <li><a href="/Testimonials">Depoimentos</a></li>
                    <li><a href="/Blog">Blog</a></li>
                </ul>
            </section>

            <section>
                <h2 class="footer-title">Solucoes</h2>
                <ul class="footer-links">
                    <li><a href="/Services/Software">Software sob medida</a></li>
                    <li><a href="/Services/WebApps">Web apps</a></li>
                    <li><a href="/Services/MobileApps">Aplicativos</a></li>
                    <li><a href="/Services/Automations">Automacoes</a></li>
                </ul>
            </section>

            <section>
                <h2 class="footer-title">Contato</h2>
                <ul class="footer-links">
                    @if (!string.IsNullOrWhiteSpace(app.ContactEmail))
                    {
                        <li><a href="mailto:@app.ContactEmail">@app.ContactEmail</a></li>
                    }
                    <li><a href="/Company/Contact">Solicitar proposta</a></li>
                    @if (!string.IsNullOrWhiteSpace(whatsappHref))
                    {
                        <li><a href="@whatsappHref" target="_blank" rel="noopener noreferrer">Falar no WhatsApp</a></li>
                    }
                    <li><a href="/Legal/Privacy">Privacidade</a></li>
                </ul>
            </section>
        </div>
        <div class="footer-bottom">
            <div class="container footer-bottom-inner">
                <p>&copy; @DateTime.UtcNow.Year @app.CompanyName. Todos os direitos reservados.</p>
                <div class="footer-bottom-links">
                    <a href="/Legal/Privacy">Politica de Privacidade</a>
                    <a href="/Legal/Terms">Termos de Uso</a>
                    <a href="/Home/Accessibility">Acessibilidade</a>
                </div>
            </div>
        </div>
    </footer>

    @if (!string.IsNullOrWhiteSpace(whatsappHref))
    {
        <a class="float-whatsapp" href="@whatsappHref" target="_blank" rel="noopener noreferrer" aria-label="Falar no WhatsApp">
            <i class="fab fa-whatsapp"></i>
        </a>
    }

    <button id="chatWidget" class="chat-widget" type="button" aria-label="Abrir assistente comercial" data-open-chat>
        <span class="chat-widget-pulse" aria-hidden="true"></span>
        <span>Assistente</span>
    </button>
    <aside id="chatPanel" class="chat-panel" aria-label="Assistente comercial" aria-hidden="true">
        <div class="chat-header">
            <div>
                <strong>Assistente @app.CompanyName</strong>
                <span>Diagnostico comercial em tempo real</span>
            </div>
            <button id="chatClose" type="button" aria-label="Fechar chat">Fechar</button>
        </div>
        <div id="chatMessages" class="chat-messages" aria-live="polite"></div>
        <form id="chatForm" class="chat-form">
            <label class="sr-only" for="chatInput">Mensagem para o assistente</label>
            <input id="chatInput" type="text" placeholder="Ex: preciso vender mais pelo site" maxlength="280" autocomplete="off" required />
            <button type="submit" class="btn btn-primary">Enviar</button>
        </form>
    </aside>

    <script defer src="~/js/site.js" asp-append-version="true"></script>
    <script defer src="~/js/chat.js" asp-append-version="true"></script>
    <script defer src="~/js/theme.js" asp-append-version="true"></script>
    <script defer src="~/js/consent.js" asp-append-version="true"></script>
    <script defer src="~/js/analytics.js" asp-append-version="true"></script>
    <script defer src="~/js/sw-register.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
