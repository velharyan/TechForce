@using Microsoft.Extensions.Options
@inject IOptions<AppOptions> AppOptions
@inject IOptions<SeoOptions> SeoOptions
@{
    var app = AppOptions.Value;
    var seo = SeoOptions.Value;
    var title = ViewData["Title"] as string ?? seo.DefaultTitle;
    var description = ViewData["Description"] as string ?? seo.DefaultDescription;
    var path = (Context?.Request?.Path.Value ?? "/").ToLowerInvariant();
    var pathSegments = path.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
    var sectionKey = pathSegments.Length > 0 ? pathSegments[0] : "home";
    var pageKey = pathSegments.Length > 1 ? $"{sectionKey}-{pathSegments[1]}" : sectionKey;
    var baseUrl = seo.BaseUrl?.TrimEnd('/');
    var canonical = !string.IsNullOrWhiteSpace(baseUrl) ? $"{baseUrl}{Context?.Request?.Path.Value}" : null;
    var ogImage = !string.IsNullOrWhiteSpace(seo.OgImage) ? seo.OgImage : Url.Content("~/img/og-default.png");

    var normalizedWhatsApp = System.Text.RegularExpressions.Regex.Replace(app.WhatsAppNumber ?? string.Empty, "[^0-9]", string.Empty);
    var whatsappHref = string.IsNullOrWhiteSpace(normalizedWhatsApp) ? null : $"https://wa.me/{normalizedWhatsApp}";
}
<!DOCTYPE html>
<html lang="pt-BR" class="no-js" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="author" content="@app.CompanyName" />
    <title>@title</title>
    <meta name="description" content="@description" />
    @if (!string.IsNullOrWhiteSpace(canonical))
    {
        <link rel="canonical" href="@canonical" />
    }
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@title" />
    <meta property="og:description" content="@description" />
    @if (!string.IsNullOrWhiteSpace(canonical))
    {
        <meta property="og:url" content="@canonical" />
    }
    <meta property="og:image" content="@ogImage" />
    <meta name="theme-color" content="#090a10" />
    <script>
        (function () {
            try {
                var savedTheme = localStorage.getItem("nxc_theme");
                if (savedTheme === "dark" || savedTheme === "light") {
                    document.documentElement.setAttribute("data-theme", savedTheme);
                }
            } catch (_error) { }
        })();
    </script>
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "Organization",
        "name": "@app.CompanyName",
        "url": "@seo.BaseUrl",
        "description": "@seo.DefaultDescription"
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/utils.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/refactor-overrides.css" asp-append-version="true" />
</head>
<body data-section="@sectionKey" data-page="@pageKey">
    <a class="skip-link" href="#conteudo">Ir para o conteudo principal</a>

    <div id="scrollProgress" class="scroll-progress" aria-hidden="true"></div>
    <div class="bg-glow bg-glow-a" aria-hidden="true"></div>
    <div class="bg-glow bg-glow-b" aria-hidden="true"></div>
    <canvas id="ambientCanvas" aria-hidden="true"></canvas>

    @await Html.PartialAsync("_Navbar")

    <main id="conteudo" class="site-main" role="main" tabindex="-1">
        @RenderBody()
    </main>

    @await Html.PartialAsync("_Footer")

    @if (!string.IsNullOrWhiteSpace(whatsappHref))
    {
        <a id="floatingWhatsapp" class="float-whatsapp" href="@whatsappHref" target="_blank" rel="noopener noreferrer" aria-label="Abrir conversa no WhatsApp">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.52 3.478A11.78 11.78 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                <path d="M17.472 14.382c-.297-.149-.937-.867-2.03-.967-.197-.1-.39-.1-.56.067-.77.75-1.1 1.63-3.16 3.26-1.9 1.4-4.18 2.0-6.37 1.2-1.76-.6-4.05-2.35-4.7-5.03-.33-1.45-.13-2.8.35-3.84 1.17-2.56 2.96-4.03 4.2-4.84 1.05-.67 2.34-1.03 3.66-.83 0 0 .58.1.84.61.33.65.93 2.12 1.01 2.28.08.16.13.35.03.54l-.39.61c-.1.16-.17.27-.33.4-.16.13-.35.3-.51.45-.17.16-.35.34-.15.67.2.34 1.16 1.9 2.48 3.08 1.7 1.51 3.15 2 3.51 2.21.37.2.58.17.8-.1.22-.27.94-1.08 1.19-1.45.24-.36.49-.3.84-.18.35.12 2.19 1.03 2.56 1.22.37.18.62.27.71.42.08.15.08.88-.2 1.73-.26.85-.84 1.6-1.58 2.11-2.1 1.49-4.58 1.54-6.6.45z"></path>
            </svg>
        </a>
    }

    <div id="chatEntryBubble" class="chat-entry-bubble" role="status" aria-live="polite" aria-label="Mensagem de boas-vindas do assistente">
        <p>Sou o assistente da <strong>@app.CompanyName</strong>.</p>
        <small>Quero te guiar com objetividade para o próximo passo ideal da sua tecnologia.</small>
        <button id="chatEntryClose" class="chat-entry-bubble-close" aria-label="Fechar aviso" type="button">&times;</button>
    </div>

    <button id="chatWidget" class="chat-widget" type="button" aria-label="Abrir assistente virtual" data-open-chat>
        <span aria-hidden="true">&#x1F4AC;</span>
        <span class="chat-label">Falar com assistente</span>
    </button>

    <aside id="chatPanel" class="chat-panel" aria-label="Assistente TechForce" aria-hidden="true" data-chat-endpoint="/api/chat">
        <header class="chat-panel-header">
            <div class="chat-avatar" aria-hidden="true">TF</div>
            <div class="chat-header-info">
                <strong>Assistente TechForce</strong>
                <span class="chat-online"><span aria-hidden="true"></span>Online agora</span>
            </div>
            <button id="chatClose" class="chat-header-close" type="button" aria-label="Fechar chat">&times;</button>
        </header>
        <div class="chat-panel-body">
            <div class="chat-lead-panel" aria-live="polite">
                <span data-lead-chip="name">Nome: pendente</span>
                <span data-lead-chip="sector">Setor: pendente</span>
                <span data-lead-chip="phone">Contato: pendente</span>
            </div>
            <div id="chatMessages" class="chat-messages" aria-live="polite" style="scroll-behavior:smooth"></div>
            <div id="chatSuggestions" class="chat-suggestions" aria-label="Sugestoes rapidas"></div>
            <form id="chatForm" class="chat-form">
                <label class="sr-only" for="chatInput">Mensagem para o assistente</label>
                <input id="chatInput" type="text" placeholder="Escreva aqui..." maxlength="280" autocomplete="off" required />
                <button type="submit" class="btn btn-primary">Enviar</button>
            </form>
        </div>
    </aside>

    <div id="demoModal" class="demo-modal" aria-hidden="true" hidden>
        <div class="demo-overlay" data-demo-close></div>
        <section class="demo-window" role="dialog" aria-modal="true" aria-labelledby="demoModalTitle">
            <header class="demo-window-header">
                <div>
                    <p id="demoModalKicker" class="eyebrow">Demo interativa</p>
                    <strong id="demoModalTitle">Demo</strong>
                </div>
                <button class="demo-close" data-demo-close type="button" aria-label="Fechar demo">&times;</button>
            </header>
            <div class="demo-browser">
                <div class="demo-address-bar">
                    <strong>Tech Studio Browser</strong>
                    <span id="demoModalAddress">https://...</span>
                </div>
                <p id="demoModalLoader" class="demo-loading" aria-hidden="true">
                    <span>Carregando experiência no simulador</span>
                    <span class="typing-dots" aria-hidden="true"><span></span><span></span><span></span></span>
                </p>
                <iframe id="demoModalFrame" class="demo-frame" src="about:blank" loading="lazy" title="Visualizador de demo" allowfullscreen></iframe>
            </div>
        </section>
    </div>

    <script defer src="~/js/site.js" asp-append-version="true"></script>
    <script defer src="~/js/demos.js" asp-append-version="true"></script>
    <script defer src="~/js/chat.js" asp-append-version="true"></script>
    <script defer src="~/js/analytics.js" asp-append-version="true"></script>
</body>
</html>
