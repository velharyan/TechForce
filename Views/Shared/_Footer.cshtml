@using Microsoft.Extensions.Options
@inject IOptions<AppOptions> App
@inject IOptions<SeoOptions> SeoOptions
@{
    var app = App.Value;
    var seo = SeoOptions.Value;
    var normalizedWhatsApp = System.Text.RegularExpressions.Regex.Replace(app.WhatsAppNumber ?? string.Empty, "[^0-9]", string.Empty);
    var whatsappHref = string.IsNullOrWhiteSpace(normalizedWhatsApp) ? null : $"https://wa.me/{normalizedWhatsApp}";
}

<footer class="site-footer">
    <div class="container footer-grid">
        <section class="footer-brand">
            <a class="brand footer-logo" href="/" aria-label="Voltar para home">
                <img src="~/img/logo3.png" asp-append-version="true" alt="@app.CompanyName" />
                <span>@app.CompanyName</span>
            </a>
            <p>
                @(
                    string.IsNullOrWhiteSpace(app.Tagline)
                    ? "Arquitetura de produto, operação e decisão para empresas que vendem com previsibilidade."
                    : app.Tagline
                )
            </p>
            <div class="footer-trust">
                <article><strong>Mais de 10</strong><span>segmentos atendidos</span></article>
                <article><strong>R$ 1,8M+</strong><span>recorrência gerenciada por projetos ativos</span></article>
                <article><strong>4+ anos</strong><span>de projetos com indicadores de ganho real</span></article>
            </div>
            <div class="footer-social">
                <a href="mailto:@app.ContactEmail" aria-label="Enviar e-mail para contato">
                    <span>✉</span>
                </a>
                @if (!string.IsNullOrWhiteSpace(whatsappHref))
                {
                    <a href="@whatsappHref" target="_blank" rel="noopener noreferrer" aria-label="Contato por WhatsApp">
                        <span>WA</span>
                    </a>
                }
                <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn TechForce">
                    <span>in</span>
                </a>
            </div>
        </section>

        <section>
            <h2 class="footer-title">Empresa</h2>
            <ul class="footer-links">
                <li><a href="/Company/About">Quem somos</a></li>
                <li><a href="/Company/Contact">Contato comercial</a></li>
                <li><a href="/Cases">Casos comprovados</a></li>
                <li><a href="/Testimonials">Depoimentos</a></li>
                <li><a href="/Home/Accessibility">Acessibilidade</a></li>
            </ul>
        </section>

        <section>
            <h2 class="footer-title">Soluções</h2>
            <ul class="footer-links">
                <li><a href="/Services">Portfólio de serviços</a></li>
                <li><a href="/Products">Demos por produto</a></li>
                <li><a href="/Products/Example/site">Site institucional</a></li>
                <li><a href="/Products/Example/ia">IA aplicada ao atendimento</a></li>
                <li><a href="/Products/Example/automation">Automações</a></li>
            </ul>
        </section>

        <section>
            <h2 class="footer-title">Início orientado a ação</h2>
            <ul class="footer-links">
                <li><a href="/Company/Chat">Começar conversa com assistente</a></li>
                <li><a href="/Products">Laboratório de demonstrações</a></li>
                <li><a href="/Blog">Artigos de execução e operação</a></li>
                <li><a href="/Legal/Privacy">Privacidade</a></li>
                <li><a href="/Legal/Terms">Termos</a></li>
            </ul>
            <div class="footer-legal">
                <a class="btn btn-outline" href="/Company/Contact">Marcar conversa executiva</a>
            </div>
        </section>
    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-inner">
            <p>&copy; @DateTime.UtcNow.Year @app.CompanyName. Todos os direitos reservados.</p>
            <div class="footer-bottom-links">
                <a href="/Legal/Privacy">Privacidade</a>
                <a href="/Legal/Terms">Termos</a>
                <a href="@seo.BaseUrl">Sitemap</a>
            </div>
        </div>
    </div>
</footer>

